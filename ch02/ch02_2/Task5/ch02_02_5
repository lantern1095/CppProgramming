#include <iostream>

using namespace std;
int main() {
	char text[100];
	int i = 0;

	cout << "빈칸 없이 문자열을 입력하세요>>";
	cin.getline(text, sizeof(text), '\n');

	while (text[i] != '\0') {
		cout << text[i] << " ";
		i++;
	}

	return 0;
};
