#include <iostream>

using namespace std;
int main() {
	double num = 0;
	double sum = 0;

	cout << "실수 5개를 입력하세요 : ";
	for (int i = 0; i < 5; i++) {
		cin >> num;
		if (num > 0) {
			sum += num;
		}
	}

	cout << "양수 합은 " << sum << "입니다.";


	return 0;
}
