#include <iostream>
#include <cstring>

using namespace std;
int main() {
    char text[100];
    int count = 0;
    int i = 0;

    while (true) {
        count = 0;
        i = 0;

        cout << "영문 텍스트를 입력하세요(빈칸 포함 가능)>>";
        cin.getline(text, sizeof(text), '\n');

        if (strcmp(text, "exit") == 0) {
            break;
        }
        else {
            while (text[i] != '\0') {
                if (text[i] != ' ' && (i == 0 || text[i - 1] == ' ')) {
                    count++;
                }
                i++;
            }
        }

        cout << "단어의 갯수는 " << count << "개이다.\n";
    }

    return 0;
}
